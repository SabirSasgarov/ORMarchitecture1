					CreatedDate = new DateTime(2024, 1, 1),
					IsDeleted = false
				},
				new Product
				{
					Id = Guid.Parse("88888888-8888-8888-8888-888888888888"),
					Name = "Cheesecake",
					Description = "Classic baked cheesecake",
					Price = 4.50m,
					CategoryId = Guid.Parse("33333333-3333-3333-3333-333333333333"), // Desserts
